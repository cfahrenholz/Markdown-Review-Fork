{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Review",
  "version": "0.1.0",
  "identifier": "de.zeitgewinn-hamburg.markdown-review",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Markdown Document",
        "role": "Editor"
      }
    ]
  }
}
